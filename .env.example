# Optional. When configured, Overwatch uses Claude for thesis and newsletter synthesis.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Auth (Clerk) ---------------------------------------------------------
# Sign-in + per-user sync. Leave BOTH unset to run the desk local-only (no
# sign-in UI, everything stored in browser memory — the default behavior).
#
# Frontend publishable key (safe to expose; must be prefixed VITE_ for Vite):
VITE_CLERK_PUBLISHABLE_KEY=
# Backend secret key (server-only — used by /api routes to verify sessions in
# later phases; NEVER expose to the client or prefix with VITE_):
CLERK_SECRET_KEY=

# --- Archive / per-user storage (Upstash Redis) ---------------------------
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# (UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN are accepted aliases)

# --- Optional news enrichment ---------------------------------------------
# FINNHUB_API_KEY=

# --- Newsletter ingest ----------------------------------------------------
# ARCHIVE_INGEST_SECRET=
