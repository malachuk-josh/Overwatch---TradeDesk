# Optional. When configured, Overwatch uses Claude for thesis synthesis and grounded
# research briefs. Thesis defaults to Haiku; research defaults to Sonnet.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
ANTHROPIC_RESEARCH_MODEL=claude-sonnet-5

# --- Auth (Clerk) ---------------------------------------------------------
# Sign-in + per-user sync. Leave BOTH unset to run the desk local-only (no
# sign-in UI, everything stored in browser memory — the default behavior).
#
# Frontend publishable key (safe to expose; must be prefixed VITE_ for Vite):
VITE_CLERK_PUBLISHABLE_KEY=
# Backend secret key (server-only — used by /api routes to verify sessions in
# later phases; NEVER expose to the client or prefix with VITE_):
CLERK_SECRET_KEY=
# Optional comma-separated deployment origins accepted in Clerk session tokens:
CLERK_AUTHORIZED_PARTIES=

# --- Archive / per-user storage (Upstash Redis) ---------------------------
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# (UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN are accepted aliases)

# --- Finnhub (news + real-time US equity/ETF quotes) ----------------------
# Free tier. When set, US ETFs (SPY/QQQ/DIA/IWM/SMH/HYG) and the Mag 7 are quoted
# real-time from Finnhub; without it they fall back to the delayed scanner/Yahoo
# feed. Indices, futures, rates, FX and commodities stay delayed either way
# (real-time there needs a paid exchange entitlement).
# FINNHUB_API_KEY=

# --- Newsletter ingest ----------------------------------------------------
# ARCHIVE_INGEST_SECRET=
# Immutable Clerk user id allowed to delete Journal entries (preferred):
# ARCHIVE_ADMIN_USER_ID=
# Verified-email fallback when an immutable id is not yet configured:
# ARCHIVE_ADMIN_EMAIL=
